# MY SOLUTION 

class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        set<int> s(nums.begin(),nums.end());
        nums.assign(s.begin(),s.end());
        return s.size();
        
    }
};





# OPTIMAL SOLUTION
class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        if(n==0) return 0;
        
        int i = 0;
        for(int j=1; j<n; j++) {
            if(nums[j]==nums[i]) {
                continue;
            } else {
                i++;
                nums[i] = nums[j];
            }
        }
        return i+1;
    }
};
