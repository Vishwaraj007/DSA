class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        int n = nums.size();
        if(nums.size() == 0) return 0;
        int i =0 ;
        for(int j=0;j<nums.size();j++)
        {
            if(nums[j] == val)
            {
                nums.erase(nums.begin()+j);
                j--;
                i++;
            }
            
        }
        return n - i;
    }
};
