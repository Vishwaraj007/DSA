class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int j=0;
        int size = nums.size();
        for(int i : nums)
        {
            if(i != 0)
            {
                nums[j] = i;
                j++;
            }
            else
            {
                continue;
            }
        }
        while(j<size)
        {
            nums[j] = 0;
            j++;
        }
    }
};
