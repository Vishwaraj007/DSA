class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        unordered_map<char,int> map;
        int longest = 0;
        int left = 0;
        for(int right =0; right < s.size();right++)
        {
            map[s[right]]++;
            while(map[s[right]] > 1)
            {
                map[s[left]]--;
                left++;
            }
            longest = max(longest, right-left+1);
        }
        return longest;

    }
};
