class Solution {
public:
    int firstUniqChar(string s) {
        unordered_map<char,int> map;
        for(char c : s)
        {
                map[c]++;
        }
        int i =0;
        for(char c : s)
        {
            if(map[c] == 1)
            {
                return i;
            }
            i++;
        }
        return -1;
    }
};
