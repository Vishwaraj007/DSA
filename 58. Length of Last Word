class Solution {
public:
    int lengthOfLastWord(string s) {
        int ans = 0;
        if(s.size() == 1)
        {
            return 1;
        }
        for(int i = s.size()-1; i>=0;i--)
        {
            cout<<s[i];
            if(s[i] == ' ')
            {
                continue;
            }
            else
            {
                ans++;
                if(i == 0 || s[i-1] == ' ')
                {
                    return ans;
                }   
            }
        }
        return ans;
    }
};
