class Solution {
public:
    int search(vector<int>& nums, int target) {
        
        
        int min =0;
        int ind;
        int max = nums.size()-1;
        
        while(min <= max)
        {
            int mid = (max+min)/2;
            if(nums[mid] == target)
            {
                return mid;
            }
            else if(nums[mid] > target)
            {
                max = mid-1;
            }
            else if(nums[mid] < target)
            {
                min = mid+1;
            }
        }
        return -1;
    }
};
